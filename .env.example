MCP_API_KEY=change-me
LLM_API_BASE=http://host.docker.internal:8000/v1
AGENTSCOPE_STUDIO_URL=http://host.docker.internal:3000
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-AWQ
DISPLAY=:0
ROS_DOMAIN_ID=42
MCP_SAFETY_PROFILE=testing
# Planning: none | basic | moveit2
MCP_PLANNER=basic
MCP_PLANNER_SYNC_PERCEPTION=true
MCP_PLANNER_CLEARANCE_MM=80
MCP_COLLISION_PADDING_MM=15
VIZ_MODE=x11
NOVNC_PORT=6080
# Perception (phase 4): none | mock | aruco
MCP_PERCEPTION=mock
# Required when MCP_PERCEPTION=aruco. Path inside the container.
MCP_PERCEPTION_CALIBRATION=
MCP_PERCEPTION_CAMERA=0
MCP_PERCEPTION_MOCK_FILE=
